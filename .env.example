# Kopiraj u .env i po potrebi izmeni vrednosti.

# PostgreSQL
POSTGRES_DB=rental
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental

# JWT (u produkciji OBAVEZNO promeni; mora imati >= 32 bajta)
APP_JWT_SECRET=promeni-me-u-produkciji-najmanje-32-bajta-tajni-kljuc
APP_JWT_EXPIRATION_MS=86400000

# CORS - dozvoljeni frontend origini
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
